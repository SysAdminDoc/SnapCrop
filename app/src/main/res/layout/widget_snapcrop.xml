<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="@string/widget_title"
        android:textColor="#EDEDF2"
        android:textSize="15sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_privacy_status"
        android:textColor="#B8B8C2"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_latest"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_action_background"
            android:contentDescription="@string/widget_latest_cd"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_crop" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_latest"
                android:textColor="#EDEDF2"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_quick_crop"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_action_background"
            android:contentDescription="@string/widget_quick_crop_cd"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_shortcut_last_action" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_quick_crop"
                android:textColor="#EDEDF2"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_gallery"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_action_background"
            android:contentDescription="@string/widget_gallery_cd"
            android:gravity="center"
            android:minHeight="48dp"
            android:orientation="vertical"
            android:padding="6dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_shortcut_gallery" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_gallery"
                android:textColor="#EDEDF2"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
