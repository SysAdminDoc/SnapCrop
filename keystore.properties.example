## SnapCrop signing config — local copy lives at `keystore.properties` (gitignored).
## storeFile is resolved relative to the repository root.
## CI/CD can supply these via env vars instead:
##   SNAPCROP_KEYSTORE_PATH, SNAPCROP_KEYSTORE_PASSWORD, SNAPCROP_KEY_ALIAS, SNAPCROP_KEY_PASSWORD
storeFile=snapcrop-release.jks
storePassword=changeme
keyAlias=snapcrop
keyPassword=changeme
